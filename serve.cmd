@REM 双击启动 HTTP 服务器，手机在同个 WiFi 下可访问
@echo off
cd /d "%~dp0"
echo ========================================
echo   A股盘后复盘台 - 局域网静态服务器
echo ========================================
echo.
echo 请在浏览器打开：http://127.0.0.1:8765
echo 手机在同个 WiFi 下访问上面的地址（把 127.0.0.1 换成电脑IP）
echo.
echo 按 Ctrl+C 可停止服务器
echo ========================================
python -m http.server 8765 --bind 0.0.0.0
pause
